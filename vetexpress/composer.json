{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "baileyherbert/envato": "^3.1",
        "endroid/qr-code": "^5.0",
        "google/apiclient": "^2.17",
        "guzzlehttp/guzzle": "^7.2",
        "joynala/maker": "^1.3",
        "joynala/web-installer": "^2.3",
        "kreait/laravel-firebase": "^7.0",
        "laravel/framework": "^13.0",
        "laravel/sanctum": "^4.3",
        "laravel/tinker": "^3.0",
        "maatwebsite/excel": "^3.1",
        "messagebird/php-rest-api": "^3.1",
        "mews/purifier": "^3.4",
        "milon/barcode": "^13.1",
        "mpdf/mpdf": "^8.2",
        "nwidart/laravel-modules": "^13.0",
        "openai-php/laravel": "^0.20.0",
        "pusher/pusher-php-server": "^7.2",
        "razorpay/razorpay": "^2.9",
        "spatie/laravel-permission": "^8.3",
        "stripe/stripe-php": "^13.15",
        "telesign/telesign": "^3.0",
        "twilio/sdk": "^8.2",
        "unisharp/laravel-filemanager": "^2.15",
        "vonage/client": "^4.0",
        "yabacon/paystack-php": "^2.2"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2",
        "laravel/pint": "^1.29",
        "laravel/sail": "^1.63",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.9",
        "phpunit/phpunit": "^11.5|^12.0|^13.0",
        "spatie/laravel-ignition": "^2.12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Modules\\": "Modules/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        },
        "audit": {
            "ignore": {
                "PKSA-y2cr-5h3j-g3ys": "firebase/php-jwt: no patched version available; transitive dep via messagebird/google-apiclient/firebase",
                "PKSA-2kqm-ps5x-s4f5": "firebase/php-jwt: no patched version available; transitive dep via messagebird/google-apiclient/firebase"
            }
        },
        "platform": {
            "php": "8.3.30"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
